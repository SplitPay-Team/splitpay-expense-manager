# SplitPay — Git Ignore Rules

# ── Sensitive / generated config ──────────────────────────
config/config.php

# ── Installer (must be deleted after use) ─────────────────
install.php

# ── Application logs ──────────────────────────────────────
logs/
*.log

# ── OS / editor noise ─────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

.idea/
.vscode/
*.swp
*.swo
*~

# ── Composer (not used, but just in case) ─────────────────
vendor/
composer.lock

# ── Node (not used, but just in case) ─────────────────────
node_modules/
package-lock.json
