Options -Indexes

# Redirect www to non-www (optional — update domain)
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route /api/* to the correct PHP include
  RewriteRule ^api/auth\.php$          includes/api_auth.php  [L,QSA]
  RewriteRule ^api/groups\.php$        includes/api_groups.php [L,QSA]
  RewriteRule ^api/projects\.php$      includes/api_projects.php [L,QSA]
  RewriteRule ^api/expenses\.php$      includes/api_expenses.php [L,QSA]
  RewriteRule ^api/settlements\.php$   includes/api_settlements.php [L,QSA]
  RewriteRule ^api/notifications\.php$ includes/api_notifications.php [L,QSA]

  # Route /pages/* to templates
  RewriteRule ^pages/login\.php$         templates/login.html       [L]
  RewriteRule ^pages/register\.php$      templates/register.html    [L]
  RewriteRule ^pages/dashboard\.php$     templates/dashboard.php    [L,QSA]
  RewriteRule ^pages/group\.php$         templates/group.php        [L,QSA]
  RewriteRule ^pages/project\.php$       templates/project.php      [L,QSA]
  RewriteRule ^pages/expense-detail\.php$ templates/expense-detail.php [L,QSA]
  RewriteRule ^pages/notifications\.php$ templates/notifications.php [L,QSA]
  RewriteRule ^pages/profile\.php$       templates/profile.php      [L,QSA]
  RewriteRule ^pages/group-create\.php$  templates/group-create.php [L,QSA]

  # Default: root → login or dashboard
  RewriteRule ^$ pages/login.php [R=302,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com;"
</IfModule>

# Protect sensitive files
<FilesMatch "(config\.php|\.env|composer\.json|composer\.lock)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# PHP settings
<IfModule mod_php.c>
  php_flag display_errors Off
  php_flag log_errors On
  php_value session.cookie_httponly 1
  php_value session.cookie_samesite Strict
  php_value session.use_strict_mode 1
</IfModule>
